{
  "name": "nitin-birthday-tribute",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "A cinematic birthday tribute for Nitin.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 7777",
    "start": "npm run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 7778",
    "score": "node scripts/generate-score.mjs",
    "remotion:studio": "remotion studio src/remotion/index.ts",
    "render:landscape": "remotion render src/remotion/index.ts NitinTributeLandscape out/nitin-tribute-landscape.mp4",
    "render:story": "remotion render src/remotion/index.ts NitinTributeStory out/nitin-tribute-story.mp4",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@remotion/player": "^4.0.379",
    "canvas-confetti": "^1.9.3",
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "lenis": "^1.3.15",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.379",
    "three": "^0.181.1",
    "tone": "^15.1.22",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.379",
    "@tailwindcss/vite": "^4.1.17",
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  }
}
